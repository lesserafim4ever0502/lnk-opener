{
  "name": "lnk-opener",
  "displayName": "Lnk Opener & Markdown Preview",
  "publisher": "lesserafim4ever0502",
  "repository": {
    "type": "git",
    "url": "https://github.com/lesserafim4ever0502/lnk-opener"
  },
  "description": "Opens Windows .lnk files natively and provides a custom Markdown preview that supports .lnk links.",
  "version": "1.0.4",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "lnkOpener.editor",
        "displayName": "Lnk Opener",
        "selector": [
          {
            "filenamePattern": "*.lnk"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "lnkOpener.showPreview",
        "title": "Markdown Preview (lnk support)",
        "icon": "$(flame)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "lnkOpener.showPreview",
          "group": "navigation",
          "when": "resourceLangId == markdown"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "tsc -noEmit -p ./",
    "watch": "npm run esbuild-base -- --sourcemap --watch"
  },
  "dependencies": {
    "@iktakahiro/markdown-it-katex": "^4.0.1",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "tlds": "^1.261.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.1",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.1.3"
  }
}
